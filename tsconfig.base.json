{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ai-writing-studio/contracts": ["packages/contracts/src/index.ts"],
      "@ai-writing-studio/openclaw-adapter": ["packages/openclaw-adapter/src/index.ts"]
    }
  }
}
